{
  "name": "sitecore-marketplace-sdk",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "test": "turbo run test",
    "build": "turbo run build",
    "build:serial": "pnpm -r --stream build",
    "clean": "turbo run clean",
    "lint": "turbo run lint",
    "test:all": "turbo run test",
    "test:shared": "cd packages/xmc && pnpm exec vitest run --config ../shared/vitest.config.ts --root ../shared",
    "coverage": "turbo run coverage",
    "generate:module": "turbo run generate:module",
    "generate:module:experimental": "turbo run generate:module:experimental",
    "pack:client": "cd packages/client && pnpm pack",
    "pack:core": "cd packages/core && pnpm pack",
    "pack:xmc": "cd packages/xmc && pnpm pack",
    "pack:ai": "cd packages/ai && pnpm pack",
    "pack:all": "pnpm pack:core && pnpm pack:client && pnpm pack:xmc && pnpm pack:ai",
    "postinstall": "pnpm build:serial",
    "changeset": "changeset",
    "empty-changeset": "pnpm changeset --empty",
    "generate:docs": "turbo run generate:docs"
  },
  "pnpm": {
    "auditConfig": {
      "ignoreCves": [
        "CVE-2025-69873"
      ]
    },
    "overrides": {
      "handlebars": "4.7.9",
      "rollup": "4.59.0",
      "serialize-javascript": "7.0.3",
      "tar": "7.5.11",
      "minimatch": "10.2.3",
      "flatted": "3.4.2",
      "undici": "7.24.0"
    }
  },
  "author": {
    "name": "Sitecore Corporation"
  },
  "license": "Apache-2.0",
  "description": "Marketplace SDK",
  "devDependencies": {
    "@changesets/cli": "2.29.2",
    "jest-environment-jsdom": "^29.7.0",
    "turbo": "^2.6.1",
    "typedoc": "^0.28.14",
    "typedoc-plugin-markdown": "^4.9.0",
    "typescript": "^5.8.2"
  },
  "packageManager": "pnpm@10.6.3"
}
